{
  "name": "@lootvm/registry-docs",
  "version": "0.1.0",
  "description": "LootVM UI — component usage docs for docs site and MCP",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@lootvm/typescript-config": "workspace:*",
    "rimraf": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sumariw4/lootvm-ui.git",
    "directory": "packages/registry-docs"
  }
}
